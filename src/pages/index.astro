---
import Layout from '../layouts/Layout.astro';

const products = [
  {
    name: "EasyAIAgents",
    role: "Automation & Intelligence",
    desc: "Deploy autonomous AI agents that handle business logic, content creation, and developer workflows with zero friction.",
    gradient: "from-purple-500 to-blue-500"
  },
  {
    name: "Lumina",
    role: "Android Video Editor",
    desc: "A professional-grade mobile suite designed for the next generation of creators. Fast, intuitive, and extremely powerful.",
    gradient: "from-orange-400 to-rose-500"
  },
  {
    name: "Max OS",
    role: "Next-Gen Computing",
    desc: "Redefining the operating system. Built for performance and compatibility, designed for the future of application ecosystems.",
    gradient: "from-emerald-400 to-cyan-500"
  }
];

const socials = [
  { name: 'Twitter', url: 'https://x.com/basixa', icon: 'M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z' },
