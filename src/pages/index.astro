---
import Layout from '../layouts/Layout.astro';

const products = [
  {
    id: "01",
    name: "EasyAIAgents",
    tagline: "Autonomous Workflow Intelligence",
    description: "Our core agentic framework designed to automate complex multi-step reasoning tasks for enterprise-level developers and researchers.",
  },
  {
    id: "02",
    name: "Lumina",
    tagline: "High-Performance Visual Engine",
    description: "A next-generation video processing suite built on low-level Android kernels, optimized for professional content synthesis.",
  },
  {
    id: "03",
    name: "Max OS",
    tagline: "The Future of Computing",
    description: "An experimental operating system project focusing on extreme performance, broad compatibility, and native AI integration.",
  }
];

const socials = [
  { name: 'Twitter', url: 'https://x.com/basixa' },
  { name: 'GitHub', url: 'https://github.com/basixa' },
  { name: 'Instagram', url: 'https://instagram.com/basixa' },
  { name: 'LinkedIn', url: 'https://linkedin.com/company/basixa' }
];
---

<Layout title="BasiXa | Building the Future of Software">
	
	<!-- Header -->
	<nav class="fixed top-0 w-full z-50 border-b border-white/[0.08] bg-[#0a0a0a]/80 backdrop-blur-xl">
		<div class="max-w-screen-2xl mx-auto px-6 md:px-12 h-20 flex justify-between items-center">
			<a href="/" class="text-xl font-bold tracking-tight hover:opacity-70 transition">BASIXA</a>
			<div class="flex items-center gap-8 text-[13px] font-medium tracking-wide uppercase text-neutral-400">
				<a href="#products" class="hover:text-white transition">Products</a>
				<a href="#vision" class="hover:text-white transition">Vision</a>
				<a href="mailto:basixaofficial@gmail.com" class="text-white border border-white/20 px-4 py-2 rounded-full hover:bg-white hover:text-black transition">Contact</a>
			</div>
		</div>
	</nav>

	<main>
		<!-- Hero Section -->
		<section class="pt-48 pb-32 px-6 md:px-12 max-w-screen-2xl mx-auto">
			<div class="max-w-4xl">
				<h1 class="text-5xl md:text-8xl font-medium tracking-tighter leading-[1.05] mb-12">
					Building the next generation of <span class="text-neutral-500 italic">intelligent computing.</span>
				</h1>
				<p class="text-lg md:text-2xl text-neutral-400 leading-relaxed max-w-2xl font-light">
					BasiXa is a technology lab focused on artificial intelligence, creative systems, and advanced computing platforms.
				</p>
			</div>
		</section>

		<!-- Product Grid (Anthropic Style) -->
		<section id="products" class="border-t border-white/[0.08] py-32 px-6 md:px-12 max-w-screen-2xl mx-auto">
			<div class="flex flex-col md:flex-row justify-between items-start gap-12">
				<div class="w-full md:w-1/3">
					<h2 class="text-sm font-semibold uppercase tracking-[0.2em] text-neutral-500 mb-4">Core Research</h2>
					<p class="text-neutral-400 text-sm leading-relaxed">We develop tools that empower creators and businesses to innovate without limits.</p>
				</div>
				<div class="w-full md:w-2/3 grid gap-12">
					{products.map(p => (
						<div class="group border-b border-white/[0.08] pb-12">
							<div class="flex justify-between items-start mb-6">
								<span class="text-xs font-mono text-neutral-600">{p.id}</span>
								<h3 class="text-3xl md:text-5xl font-medium tracking-tight group-hover:translate-x-2 transition-transform duration-500">
									{p.name}
								</h3>
							</div>
							<p class="text-neutral-500 text-sm uppercase tracking-widest mb-4 font-semibold">{p.tagline}</p>
							<p class="text-neutral-300 text-lg leading-relaxed max-w-xl">{p.description}</p>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- Vision Section -->
		<section id="vision" class="bg-[#111] py-32 px-6 md:px-12 border-y border-white/[0.08]">
			<div class="max-w-screen-2xl mx-auto flex flex-col md:flex-row gap-20 items-center">
				<div class="md:w-1/2">
					<h2 class="text-4xl md:text-6xl font-medium tracking-tight mb-8">Intelligence should be accessible.</h2>
					<p class="text-neutral-400 text-lg leading-relaxed mb-12">
						We believe software must be fast, creative, and open. BasiXa is building an ecosystem where advanced technology becomes simple for everyone.
					</p>
					<div class="grid grid-cols-2 gap-4">
						{['Intelligent', 'Fast', 'Creative', 'Open'].map(val => (
							<div class="p-6 border border-white/5 rounded-2xl bg-white/[0.02] text-sm font-bold uppercase tracking-widest">
								{val}
							</div>
						))}
					</div>
				</div>
				<div class="md:w-1/2 w-full aspect-square bg-gradient-to-tr from-neutral-800 to-neutral-900 rounded-[40px] flex items-center justify-center border border-white/10 relative overflow-hidden">
					<div class="absolute inset-0 opacity-20 bg-[url('https://www.transparenttextures.com/patterns/carbon-fibre.png')]"></div>
					<span class="text-[12rem] font-black opacity-5 select-none">B</span>
				</div>
			</div>
		</section>

		<!-- CEO Section -->
		<section class="py-32 px-6 md:px-12 max-w-screen-2xl mx-auto">
			<div class="flex flex-col md:flex-row gap-20 items-end">
				<div class="md:w-1/2">
					<div class="text-xs font-mono text-neutral-500 uppercase tracking-widest mb-8">Leadership</div>
					<h2 class="text-5xl md:text-7xl font-medium tracking-tight mb-8">Abdul Basit HS</h2>
					<p class="text-xl text-neutral-400 leading-relaxed font-light italic">
						"Our mission is to build technology that removes the barriers between human imagination and digital execution."
					</p>
					<div class="mt-8 pt-8 border-t border-white/10">
						<p class="text-sm font-semibold uppercase tracking-widest">Founder & CEO, BasiXa</p>
					</div>
				</div>
				<div class="md:w-1/2 w-full h-[400px] bg-neutral-900 rounded-3xl border border-white/5 flex items-center justify-center group overflow-hidden">
					<div class="text-neutral-700 text-lg font-mono group-hover:text-neutral-400 transition italic tracking-tighter uppercase">Building the future...</div>
				</div>
			</div>
		</section>
	</main>

	<!-- Footer -->
	<footer class="border-t border-white/[0.08] pt-24 pb-12 px-6 md:px-12 bg-[#050505]">
		<div class="max-w-screen-2xl mx-auto flex flex-col md:flex-row justify-between items-start gap-12 mb-24">
			<div>
				<div class="text-2xl font-bold mb-6 tracking-tighter">BASIXA</div>
				<p class="text-neutral-500 max-w-xs text-sm leading-relaxed">
					Next-generation software for the creative and intelligent age.
				</p>
			</div>
			<div class="flex gap-20">
				<div>
					<h4 class="text-[11px] font-bold uppercase tracking-[0.2em] text-neutral-600 mb-6">Social</h4>
					<ul class="space-y-4 text-sm font-medium text-neutral-400">
						{socials.map(s => (
							<li><a href={s.url} target="_blank" class="hover:text-white transition">@{s.name}</a></li>
						))}
					</ul>
				</div>
				<div>
					<h4 class="text-[11px] font-bold uppercase tracking-[0.2em] text-neutral-600 mb-6">Inquiries</h4>
					<a href="mailto:basixaofficial@gmail.com" class="text-sm font-medium text-neutral-400 hover:text-white transition">
						basixaofficial@gmail.com
					</a>
				</div>
			</div>
		</div>
		<div class="max-w-screen-2xl mx-auto pt-8 border-t border-white/5 flex flex-col md:flex-row justify-between items-center text-[11px] font-bold uppercase tracking-widest text-neutral-600">
			<p>© {new Date().getFullYear()} BASIXA LABS. All rights reserved.</p>
			<p>Pakistan — Global</p>
		</div>
	</footer>
</Layout>
