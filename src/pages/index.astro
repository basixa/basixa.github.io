---

<Layout title="BasiXa | Building the Future of Software">
	<!-- Navbar -->
	<nav class="fixed top-0 w-full z-50 border-b border-white/5 bg-black/50 backdrop-blur-md">
		<div class="max-w-7xl mx-auto px-6 h-20 flex justify-between items-center">
			<div class="text-2xl font-black tracking-tighter uppercase">BasiXa</div>
			<div class="flex gap-8 items-center">
				<a href="#products" class="text-sm text-gray-400 hover:text-white transition">Products</a>
				<a href="mailto:basixaofficial@gmail.com" class="px-5 py-2 bg-white text-black text-sm font-bold rounded-full hover:bg-gray-200 transition">Get in Touch</a>
			</div>
		</div>
	</nav>

	<main class="pt-32 pb-20 px-6 max-w-7xl mx-auto">
		<!-- Hero Section -->
		<section class="text-center py-20 relative">
			<div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-[500px] bg-purple-600/10 blur-[120px] -z-10 rounded-full"></div>
			<span class="px-4 py-1.5 rounded-full border border-purple-500/30 text-purple-400 text-xs font-bold uppercase tracking-[0.2em] mb-8 inline-block bg-purple-500/5">
				Next Generation Computing
			</span>
			<h1 class="text-6xl md:text-9xl font-black tracking-tighter mb-8 leading-[0.9] text-gradient">
				Building the <br/> Future of Software.
			</h1>
			<p class="text-xl md:text-2xl text-gray-400 max-w-3xl mx-auto leading-relaxed mb-12">
				BasiXa is an independent technology company focused on AI, creative tools, productivity software, and next-generation platforms.
			</p>
			<div class="flex flex-wrap justify-center gap-4">
				<a href="#products" class="px-8 py-4 bg-white text-black font-bold rounded-xl hover:scale-105 transition">Explore Products</a>
				<a href="#vision" class="px-8 py-4 glass font-bold hover:bg-white/5 transition">Our Vision</a>
			</div>
		</section>

		<!-- Products Section -->
		<section id="products" class="py-24">
			<div class="mb-16">
				<h2 class="text-4xl font-bold mb-4">Our Ecosystem</h2>
				<p class="text-gray-500 max-w-xl">Innovative products designed to empower creators, developers, and businesses.</p>
			</div>
			
			<div class="grid md:grid-cols-3 gap-8">
				{products.map(p => (
					<div class="glass p-10 group hover:border-white/20 transition-all">
						<div class={`w-12 h-12 rounded-lg bg-gradient-to-br ${p.gradient} mb-8 shadow-lg shadow-purple-500/20`}></div>
						<h3 class="text-2xl font-bold mb-2 group-hover:text-purple-400 transition">{p.name}</h3>
						<p class="text-xs font-bold text-gray-500 uppercase tracking-widest mb-4">{p.role}</p>
						<p class="text-gray-400 leading-relaxed text-sm">{p.desc}</p>
					</div>
				))}
			</div>
		</section>

		<!-- Vision & Mission -->
		<section id="vision" class="py-24 grid lg:grid-cols-2 gap-12 items-center">
			<div class="glass p-12 relative overflow-hidden">
				<div class="absolute -top-10 -right-10 w-40 h-40 bg-purple-500/20 blur-3xl"></div>
				<h2 class="text-3xl font-bold mb-6">Our Mission</h2>
				<p class="text-2xl font-light text-gray-300 leading-relaxed">
					"To build <span class="text-white font-bold">powerful, accessible, and intelligent</span> technology that helps people create, learn, and innovate without limits."
				</p>
			</div>
			<div class="space-y-8">
				<h2 class="text-4xl font-bold tracking-tight">Software should be...</h2>
				<div class="grid grid-cols-2 gap-4">
					{['Intelligent', 'Accessible', 'Fast', 'Creative', 'Open'].map(item => (
						<div class="flex items-center gap-3 p-4 glass border-white/5">
							<div class="w-1.5 h-1.5 bg-purple-500 rounded-full shadow-[0_0_10px_#a855f7]"></div>
							<span class="font-semibold">{item}</span>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- Founder Section -->
		<section class="py-24 border-t border-white/5">
			<div class="flex flex-col md:flex-row gap-12 items-center">
				<div class="w-48 h-48 rounded-full bg-gradient-to-br from-purple-600 to-blue-600 flex items-center justify-center text-5xl font-bold">
					AB
				</div>
				<div>
					<p class="text-purple-500 font-bold uppercase tracking-widest text-sm mb-2">Founder & CEO</p>
					<h2 class="text-5xl font-bold mb-4">Abdul Basit HS</h2>
					<p class="text-gray-400 max-w-2xl text-lg leading-relaxed">
						Driving the innovation at BasiXa with a vision to make advanced technology simple for everyone.
					</p>
				</div>
			</div>
		</section>
	</main>

	<!-- Footer -->
	<footer class="bg-[#050505] border-t border-white/5 pt-20 pb-10 px-6">
		<div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-start gap-12 mb-20">
			<div>
				<div class="text-3xl font-black mb-6 uppercase tracking-tighter">BasiXa</div>
				<p class="text-gray-500 max-w-xs">Building the future of software, one line of code at a time.</p>
			</div>
			
			<div class="grid grid-cols-2 md:grid-cols-3 gap-16">
				<div>
					<h4 class="font-bold mb-6">Socials</h4>
					<ul class="space-y-4 text-gray-500">
						{socials.map(s => (
							<li><a href={s.url} class="hover:text-white transition">@{s.name}</a></li>
						))}
					</ul>
				</div>
				<div>
					<h4 class="font-bold mb-6">Contact</h4>
					<a href="mailto:basixaofficial@gmail.com" class="text-gray-500 hover:text-white transition break-all">basixaofficial@gmail.com</a>
				</div>
			</div>
		</div>

		<div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-center pt-8 border-t border-white/5">
			<p class="text-gray-600 text-sm">© {new Date().getFullYear()} BasiXa. All rights reserved.</p>
			<div class="flex gap-6 mt-4 md:mt-0">
				{socials.map(s => (
					<a href={s.url} target="_blank" class="text-gray-500 hover:text-white transition">
						<svg class="w-5 h-5 fill-current" viewBox="0 0 24 24"><path d={s.icon}/></svg>
					</a>
				))}
			</div>
		</div>
	</footer>
</Layout>
