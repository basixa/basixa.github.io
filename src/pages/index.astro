---

<Layout title="BasiXa | Building the Future of Software">
	<main class="max-w-6xl mx-auto px-6 py-12">
		
		<!-- Navigation -->
		<nav class="flex justify-between items-center mb-24">
			<div class="text-2xl font-extrabold tracking-tighter">BasiXa</div>
			<div class="hidden md:flex gap-8 text-sm font-medium text-gray-400">
				<a href="#products" class="hover:text-white transition">Products</a>
				<a href="#vision" class="hover:text-white transition">Vision</a>
				<a href="mailto:basixaofficial@gmail.com" class="hover:text-white transition">Contact</a>
			</div>
		</nav>

		<!-- Hero Section -->
		<header class="text-center mb-32">
			<div class="inline-block px-4 py-1.5 mb-6 glass rounded-full text-xs font-semibold tracking-widest uppercase text-purple-400">
				Independent Technology Company
			</div>
			<h1 class="text-6xl md:text-8xl font-extrabold mb-8 tracking-tight">
				Building the <span class="text-gradient">Future</span> of Software.
			</h1>
			<p class="text-xl text-gray-400 max-w-2xl mx-auto leading-relaxed">
				BasiXa is focused on artificial intelligence, creative tools, productivity software, and next-generation computing platforms.
			</p>
		</header>

		<!-- Mission Section -->
		<section class="mb-32">
			<div class="glass p-12 rounded-3xl text-center">
				<h2 class="text-3xl font-bold mb-6">Our Mission</h2>
				<p class="text-2xl text-gray-300 max-w-4xl mx-auto font-light italic">
					"To build powerful, accessible, and intelligent technology that helps people create, learn, and innovate without limits."
				</p>
			</div>
		</section>

		<!-- Products Section -->
		<section id="products" class="mb-32">
			<h2 class="text-sm font-bold tracking-widest uppercase text-gray-500 mb-12">Featured Projects</h2>
			<div class="grid md:grid-cols-3 gap-8">
				{products.map(product => (
					<div class="glass p-8 rounded-2xl hover:border-purple-500/50 transition-all group">
						<div class="text-4xl mb-6">{product.icon}</div>
						<h3 class="text-xl font-bold mb-3 group-hover:text-purple-400 transition">{product.title}</h3>
						<p class="text-gray-400 text-sm leading-relaxed">{product.desc}</p>
					</div>
				))}
			</div>
		</section>

		<!-- Vision Section -->
		<section id="vision" class="mb-32 grid md:grid-cols-2 gap-16 items-center">
			<div>
				<h2 class="text-4xl font-bold mb-8">Software should be <span class="text-purple-500">Intelligent</span>.</h2>
				<p class="text-gray-400 mb-8">We believe in an ecosystem where advanced technology becomes simple for everyone. No steep learning curves, just pure innovation.</p>
				<ul class="space-y-4">
					{['Intelligent', 'Accessible', 'Fast', 'Creative', 'Open to innovation'].map(item => (
						<li class="flex items-center gap-3">
							<div class="w-2 h-2 rounded-full bg-purple-500"></div>
							<span class="font-medium">{item}</span>
						</li>
					))}
				</ul>
			</div>
			<div class="relative">
				<div class="absolute inset-0 bg-purple-600/20 blur-[100px] -z-10"></div>
				<div class="glass aspect-square rounded-3xl flex items-center justify-center p-12 text-center">
					<div>
						<p class="text-sm text-gray-500 uppercase tracking-widest mb-4">Founder & CEO</p>
						<h3 class="text-3xl font-bold mb-2">Abdul Basit HS</h3>
						<p class="text-purple-400">Driving the vision of BasiXa</p>
					</div>
				</div>
			</div>
		</section>

		<!-- Footer / Contact -->
		<footer class="pt-24 border-t border-white/10">
			<div class="flex flex-col md:flex-row justify-between items-center gap-12">
				<div>
					<div class="text-2xl font-extrabold mb-4">BasiXa</div>
					<p class="text-gray-500 text-sm">© {new Date().getFullYear()} BasiXa. All rights reserved.</p>
				</div>

				<div class="flex flex-col items-center md:items-end gap-6">
					<a href="mailto:basixaofficial@gmail.com" class="text-lg font-medium hover:text-purple-400 transition">
						basixaofficial@gmail.com
					</a>
					<div class="flex gap-6">
						{socials.map(social => (
							<a href={social.url} target="_blank" aria-label={social.name} class="text-gray-400 hover:text-white transition">
								<svg class="w-6 h-6 fill-current" viewBox="0 0 24 24">
									<path d={social.icon}/>
								</svg>
							</a>
						))}
					</div>
				</div>
			</div>
		</footer>
	</main>
</Layout>
