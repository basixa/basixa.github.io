---
interface Props { title: string; }
const { title } = Astro.props;
---
<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>B</text></svg>" />
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&display=swap" rel="stylesheet">
		<title>{title}</title>
	</head>
	<body class="bg-[#050505] text-[#f5f5f5] font-['Inter'] antialiased selection:bg-indigo-500/30">
		<!-- Background Sophisticated Glows -->
		<div class="fixed top-0 left-0 w-full h-full overflow-hidden -z-10">
			<div class="absolute -top-[10%] -left-[10%] w-[50%] h-[50%] bg-indigo-900/20 blur-[120px] rounded-full"></div>
			<div class="absolute bottom-[0%] right-[0%] w-[40%] h-[40%] bg-purple-900/10 blur-[150px] rounded-full"></div>
		</div>
		<slot />
	</body>
</html>

<style is:global>
	html { scroll-behavior: smooth; }
	::-webkit-scrollbar { width: 5px; }
	::-webkit-scrollbar-thumb { background: #222; border-radius: 10px; }
</style>
